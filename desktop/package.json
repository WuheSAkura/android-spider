{
  "name": "android-spider-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "typecheck:main": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:main && npm run typecheck:renderer"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.21",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^35.5.1",
    "electron-vite": "^3.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
